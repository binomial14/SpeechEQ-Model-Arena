# Full Google Apps Script Web App URL (Deploy → Web app → copy URL ending in /exec)
# On localhost, the dev server proxies this automatically — see vite.config.js and resolveAppsScriptUrl in src/App.jsx
VITE_GOOGLE_FORM_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

